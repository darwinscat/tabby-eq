# Build output
/build/
/cmake-build-*/
/out/
*.o
*.obj
*.a
*.lib
*.dylib
*.so
*.dll
*.exe

# Plugin bundles (built artifacts)
*.vst3
*.component
*.clap
*.aaxplugin

# JUCE / CMake fetched deps
/JUCE/
/_deps/
/CMakeFiles/
CMakeCache.txt
cmake_install.cmake

# IDEs
.idea/
.vscode/
*.xcodeproj/
*.xcworkspace/
.cache/

# macOS
.DS_Store

# Signing / secrets — NEVER commit
*.p12
*.cer
*.provisionprofile
*.entitlements.local
notarize-credentials*
.env

# Local AI-assistant brain — kept private/local, not shipped in the public repo
CLAUDE.md
.claude/

# Poweramp NAM captures — the amp-stage CODE is public/AGPL, but the .nam model files stay
# LOCAL (your own build embeds them). The open-source plugin ships without bundled third-party
# captures, like the official NAM plugin. Keep resources/poweramps/README.md tracked; ignore the models.
resources/poweramps/*.nam

# Stray build/tool logs
*.log
